# OS
.DS_Store
Thumbs.db


# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json


# Python bytecode / caches
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/


# Virtual environments
.venv/
venv/
env/
ENV/
# If you ever accidentally create a venv named exactly "Scripts" on Windows,
# uncomment the next line. For now, keep Scripts tracked since it's your venv bin.
# Scripts/


# Packaging / build metadata
*.egg-info/
backend/dist/
backend/build/
src/*.egg-info/
dist/
build/


# Backend specific
# (already covered by the global build/egg rules, but keep for clarity)
# backend/*.egg-info/


# Node / frontend
frontend/node_modules/
frontend/dist/
frontend/build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# Env files
.env
.env.*
!.env.example
!backend/.env.example
!frontend/.env.example


# Logs
*.log
logs/


# Data artifacts
# If you want to keep only sample and processed committed, ignore heavy/raw and tmp.
data/raw/
data/tmp/
data/cache/
# If you want processed data under version control, keep this as-is.
# If not, you can add:
data/processed/


# Jupyter
.ipynb_checkpoints/